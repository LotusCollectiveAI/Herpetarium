# ============================================================
# Decrypto Arena — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your keys.
# Only the providers you plan to use need keys.
# ============================================================

# --- Database (Required) ---
# PostgreSQL connection string. Neon serverless recommended.
# Sign up: https://neon.tech
DATABASE_URL=

# --- OpenAI (GPT-4o, o3, o1) ---
# Sign up: https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_API_KEY=
# Optional: custom endpoint (leave blank for default)
AI_INTEGRATIONS_OPENAI_BASE_URL=

# --- Anthropic (Claude Sonnet 4, Haiku 4) ---
# Sign up: https://console.anthropic.com/
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
# Optional: custom endpoint
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=

# --- Google (Gemini 2.0 Flash, 2.5 Pro) ---
# Sign up: https://aistudio.google.com/apikey
AI_INTEGRATIONS_GEMINI_API_KEY=

# --- OpenRouter (100+ models: DeepSeek, Grok, Llama, Mistral, etc.) ---
# Sign up: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: your site URL for OpenRouter analytics
OPENROUTER_REFERER=http://localhost:5000
# Optional: app name shown in OpenRouter dashboard
OPENROUTER_TITLE=Decrypto Arena

# --- Fallback Key Names (for local dev without Replit) ---
# If the AI_INTEGRATIONS_* keys above are empty, the app
# will also check these standard names:
# OPENAI_API_KEY, ANTHROPIC_API_KEY, GOOGLE_API_KEY

# --- Server ---
PORT=5000
NODE_ENV=development
